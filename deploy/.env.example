# Required
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Server port (default: 8080)
# PORT=8080

# API key for authenticating CLI and app requests (leave empty to disable)
# DINGIT_API_KEY=your_api_key_here

# --- APNs Push Notifications (iOS, optional) ---
# APNS_KEY_FILE=/secrets/AuthKey.p8
# APNS_KEY_ID=YOUR_KEY_ID
# APNS_TEAM_ID=YOUR_TEAM_ID
# APNS_BUNDLE_ID=com.your.app
# APNS_ENV: "sandbox" for dev/Xcode builds, "production" for TestFlight/App Store
# APNS_ENV=production

# --- FCM Push Notifications (Android, optional) ---
# FCM_PROJECT_ID=your-firebase-project
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-sa.json
