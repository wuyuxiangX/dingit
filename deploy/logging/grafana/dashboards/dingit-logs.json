{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Dingit server log overview — level distribution, recent errors, and per-source volume. Fed by the reference Loki stack at deploy/logging/docker-compose.yml (WYX-408).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": true,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "dingit-loki" },
      "description": "Zap log lines per minute, split by level. A spike on 'error' is the first thing to look at when triaging.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["last", "sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "dingit-loki" },
          "editorMode": "code",
          "expr": "sum by (level) (rate({container=\"dingit-server\"} | json [$__auto]))",
          "legendFormat": "{{level}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log rate by level",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "dingit-loki" },
      "description": "Total log lines in the current time window, split by level. Useful for 'what's the baseline vs right now' at a glance.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "dingit-loki" },
          "editorMode": "code",
          "expr": "sum by (level) (count_over_time({container=\"dingit-server\"} | json [$__range]))",
          "legendFormat": "{{level}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Totals (current window)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "dingit-loki" },
      "description": "Most recent warn/error lines. Click a row to expand the full zap JSON payload.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "dingit-loki" },
          "editorMode": "code",
          "expr": "{container=\"dingit-server\", level=~\"error|warn\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent errors & warnings",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "dingit-loki" },
      "description": "Per-source traffic mix — which notification sources are actually firing. Empty if no notifications have been sent since promtail started.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 4,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "dingit-loki" },
          "editorMode": "code",
          "expr": "sum by (log_source) (count_over_time({container=\"dingit-server\"} | json | log_source != \"\" [$__auto]))",
          "legendFormat": "{{log_source}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Notifications by source",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["dingit", "logs", "loki"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Dingit · Logs",
  "uid": "dingit-logs",
  "version": 1,
  "weekStart": ""
}
