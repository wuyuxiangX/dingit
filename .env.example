# ============================================
# Dingit Server - Environment Configuration
# ============================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env

# === Required ===

# Database password for PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# === Optional ===

# Server port exposed on host (default: 8080)
# PORT=8080

# Seed an API key on first startup.
# If omitted, one is auto-generated and printed to logs:
#   docker compose logs server | grep "Generated initial key"
# DINGIT_API_KEY=

# === Push Notifications (Optional) ===
# Place credential files in the ./secrets/ directory (auto-mounted read-only).

# -- APNs (iOS) --
# APNS_KEY_FILE=/secrets/apns-key.p8
# APNS_KEY_ID=YOUR_KEY_ID
# APNS_TEAM_ID=YOUR_TEAM_ID
# APNS_BUNDLE_ID=com.notifyhub.notifyApp
# APNS_ENV=production

# -- FCM (Android) --
# FCM_PROJECT_ID=your-firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json
