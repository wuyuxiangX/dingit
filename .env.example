# ============================================
# Dingit Server - Environment Configuration
# ============================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env

# === Required ===

# Database password for PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# === Optional ===

# Server port exposed on host (default: 8080)
# PORT=8080

# Seed an API key on first startup.
# If omitted, one is auto-generated and printed to stderr as a banner on
# first run. The full key is also written to ./secrets/.initial-api-key
# (mode 0600). To recover it later:
#   cat secrets/.initial-api-key
# Or re-read the startup banner:
#   docker compose logs server | sed -n '/DINGIT: initial API key/,/^=====/p'
# DINGIT_API_KEY=

# === Rate Limiting (Optional) ===
# Enabled by default. Set to false to disable.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BURST=20

# === Push Notifications (Optional) ===
# Place credential files in the repo-root ./secrets/ directory. That
# directory is gitignored and mounted read-only at /secrets inside
# the container. Do NOT place credential files under apps/server/configs —
# that directory is tracked and one accidental `git add` leaks them.

# -- APNs (iOS) --
# APNS_KEY_FILE=/secrets/apns-key.p8
# APNS_KEY_ID=YOUR_KEY_ID
# APNS_TEAM_ID=YOUR_TEAM_ID
# APNS_BUNDLE_ID=com.notifyhub.notifyApp
# APNS_ENV=production

# -- FCM (Android) --
# FCM_PROJECT_ID=your-firebase-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json
